# PostgreSQL (Docker Compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ticket_manager

# Database (TypeORM connection)
# Usar 'localhost' para desarrollo local, 'postgres' para Docker
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=ticket_manager

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=24h

# App
PORT=3000

# Admin Seed
ADMIN_EMAIL=admin@ticket-manager.com
ADMIN_PASSWORD=Admin123!

# SMTP (envio de reportes por correo)
# Usar app password de Gmail o credenciales de otro proveedor SMTP
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=tu-correo@gmail.com
MAIL_PASS=tu-app-password
MAIL_FROM=noreply@ticket-manager.com

# Reportes programados (correos separados por coma)
REPORT_RECIPIENTS=admin@example.com,manager@example.com
